#!/usr/bin/env bash

set -euo pipefail

say() { printf 'ryoku: %s\n' "$*"; }
die() { printf 'ryoku: %s\n' "$*" >&2; exit 1; }

usage() {
  cat <<'USAGE'
Usage: ryoku <command>

Commands:
  update   pull the repo, deploy the Ryoku shell mirror, and reload live
  reload   restart the deployed shell daemon and reload Hyprland

Env:
  RYOKU_REPO=/path/to/ryoku-arch      repo to deploy from
  RYOKU_UPDATE_SKIP_PULL=1            deploy without git pull
USAGE
}

valid_repo() {
  [[ -d $1/.git && -x $1/ryoku/shell/deploy.sh && -d $1/ryoku/hyprland ]]
}

repo_from_git() {
  local root
  root=$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || true)
  [[ -n $root && -d $root ]] || return 1
  valid_repo "$root" || return 1
  printf '%s\n' "$root"
}

repo_from_script() {
  local dir root
  dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  root="$(cd -- "$dir/../.." 2>/dev/null && pwd || true)"
  [[ -n $root ]] || return 1
  valid_repo "$root" || return 1
  printf '%s\n' "$root"
}

repo_from_default() {
  local root=$HOME/Work/ryoku-arch
  valid_repo "$root" || return 1
  printf '%s\n' "$root"
}

resolve_repo() {
  if [[ -n ${RYOKU_REPO:-} ]]; then
    valid_repo "$RYOKU_REPO" || die "RYOKU_REPO is not a Ryoku repo: $RYOKU_REPO"
    printf '%s\n' "$RYOKU_REPO"
    return
  fi

  repo_from_git && return
  repo_from_script && return
  repo_from_default && return
  die "cannot find repo; set RYOKU_REPO=/path/to/ryoku-arch"
}

ensure_clean_repo() {
  local repo=$1
  git -C "$repo" update-index -q --refresh
  if [[ -n $(git -C "$repo" status --porcelain) ]]; then
    git -C "$repo" status --short >&2
    die "repo has uncommitted changes; commit, stash, or discard them before update"
  fi
}
pull_repo() {
  local repo=$1
  local upstream branch

  upstream=$(git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
  if [[ -n $upstream ]]; then
    git -C "$repo" pull --ff-only
    return
  fi

  branch=$(git -C "$repo" branch --show-current)
  [[ -n $branch ]] || die "repo is on a detached HEAD; set an upstream before update"
  git -C "$repo" pull --ff-only origin "$branch"
}


restart_live_shell() {
  local bindir=${HOME}/.local/bin
  local shell=$bindir/ryoku-shell
  local log=${XDG_STATE_HOME:-$HOME/.local/state}/ryoku-shell.log

  command -v hyprctl >/dev/null 2>&1 && hyprctl reload >/dev/null 2>&1 || true
  [[ -x $shell ]] || die "missing deployed ryoku-shell: $shell"

  "$shell" quit >/dev/null 2>&1 || true
  for _ in {1..20}; do
    "$shell" ping >/dev/null 2>&1 || break
    sleep 0.1
  done

  mkdir -p "$(dirname -- "$log")"
  if command -v setsid >/dev/null 2>&1; then
    setsid "$shell" daemon >"$log" 2>&1 < /dev/null &
  else
    nohup "$shell" daemon >"$log" 2>&1 < /dev/null &
  fi
  say "restarted live shell daemon ($log)"
}

update() {
  local repo=$1
  ensure_clean_repo "$repo"
  if [[ ${RYOKU_UPDATE_SKIP_PULL:-0} != 1 ]]; then
    say "pulling $repo"
    pull_repo "$repo"
  fi
  ensure_clean_repo "$repo"
  say "deploying $repo/ryoku/shell -> ${XDG_CONFIG_HOME:-$HOME/.config}"
  "$repo/ryoku/shell/deploy.sh"
}

cmd=${1:-}
case "$cmd" in
  update)
    update "$(resolve_repo)"
    ;;
  reload)
    restart_live_shell
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    die "unknown command: $cmd"
    ;;
esac
