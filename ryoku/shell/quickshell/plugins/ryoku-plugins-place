#!/usr/bin/env bash
# Merge a plugin placement change into ~/.config/ryoku/plugins.json. Used by the
# desktop layer to persist a dragged tile's free position (and by Ryoku Settings
# for any placement edit). The Registry's file watch picks the change up and
# retunes every surface, so there is no reload.
#
#   ryoku-plugins-place <id> desktopWidget <x> <y>
#   ryoku-plugins-place <id> framePopout <edge> <align> <hoverW> <hoverH>
#   ryoku-plugins-place <id> host <hostName>
#   ryoku-plugins-place <id> enabled <true|false>
set -euo pipefail

cfg_home="${XDG_CONFIG_HOME:-$HOME/.config}"
f="$cfg_home/ryoku/plugins.json"
mkdir -p "$(dirname "$f")"
[ -f "$f" ] || echo '{}' >"$f"

id="${1:?id required}"; field="${2:?field required}"; shift 2

case "$field" in
desktopWidget)
	x="${1:?x}"; y="${2:?y}"; scale="${3:-}"; locked="${4:-}"
	extra='{ x: $x, y: $y }'
	args=(--arg id "$id" --argjson x "$x" --argjson y "$y")
	if [ -n "$scale" ]; then args+=(--argjson sc "$scale"); extra="$extra + { scale: \$sc }"; fi
	if [ -n "$locked" ]; then args+=(--argjson lk "$locked"); extra="$extra + { locked: \$lk }"; fi
	jq "${args[@]}" \
		".[\$id] = ((.[\$id] // {}) + { enabled: ((.[\$id].enabled) // true), host: ((.[\$id].host) // \"desktopWidget\"), desktopWidget: (((.[\$id].desktopWidget) // {}) + ($extra)) })" \
		"$f" >"$f.tmp" && mv "$f.tmp" "$f"
	;;
framePopout)
	edge="${1:?edge}"; align="${2:-start}"; hoverW="${3:-320}"; hoverH="${4:-16}"
	jq --arg id "$id" --arg e "$edge" --arg a "$align" --argjson hw "$hoverW" --argjson hh "$hoverH" \
		'.[$id] = ((.[$id] // {}) + { enabled: ((.[$id].enabled) // true), host: ((.[$id].host) // "framePopout"), framePopout: (((.[$id].framePopout) // {}) + { edge: $e, align: $a, hoverW: $hw, hoverH: $hh }) })' \
		"$f" >"$f.tmp" && mv "$f.tmp" "$f"
	;;
host)
	host="${1:?host}"
	jq --arg id "$id" --arg h "$host" '.[$id] = ((.[$id] // {}) + { enabled: ((.[$id].enabled) // true), host: $h })' "$f" >"$f.tmp" && mv "$f.tmp" "$f"
	;;
enabled)
	en="${1:?enabled}"
	jq --arg id "$id" --argjson e "$en" '.[$id] = ((.[$id] // {}) + { enabled: $e })' "$f" >"$f.tmp" && mv "$f.tmp" "$f"
	;;
*)
	echo "usage: ryoku-plugins-place <id> desktopWidget <x> <y> | host <name> | enabled <bool>" >&2
	exit 2
	;;
esac
