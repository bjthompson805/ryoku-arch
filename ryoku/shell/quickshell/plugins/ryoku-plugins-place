#!/usr/bin/env bash
# Merge a plugin placement change into ~/.config/ryoku/plugins.json. Used by the
# desktop layer to persist a dragged tile's free position, by Ryoku Settings for
# any placement edit, and by the installer to seed/forget a plugin's settings
# block. The Registry's file watch picks the change up and retunes every surface,
# so there is no reload.
#
#   ryoku-plugins-place <id> desktopWidget <x> <y> [scale] [locked]
#   ryoku-plugins-place <id> framePopout <edge> <align> <hoverW> <hoverH>
#   ryoku-plugins-place <id> host <hostName>
#   ryoku-plugins-place <id> enabled <true|false>
#   ryoku-plugins-place <id> settings <json>   merge a settings object
#   ryoku-plugins-place <id> seed              inject the manifest preset block
#   ryoku-plugins-place <id> forget            drop the whole entry (uninstall)
set -euo pipefail

cfg_home="${XDG_CONFIG_HOME:-$HOME/.config}"
data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
f="$cfg_home/ryoku/plugins.json"
mkdir -p "$(dirname "$f")"

# Self-heal: a missing, empty, or corrupt file (a stale partial write, an external
# reset) becomes a fresh {} so every write below has valid input and the readers
# (discover.sh) never choke on it.
if [ ! -s "$f" ] || ! jq -e . "$f" >/dev/null 2>&1; then
	echo '{}' >"$f"
fi

# Every write goes through a unique temp on the same filesystem, then an atomic
# rename. A unique name (not a shared "$f.tmp") means two writers landing at once
# - a desktop drag committing while Settings toggles enabled, say - can at worst
# lose one update, never truncate the file to nothing.
tmp="$(mktemp "$f.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

id="${1:?id required}"; field="${2:?field required}"; shift 2

# Print a plugin's manifest path, searching the dev override dirs then the data
# dir (the same order discover.sh uses). Non-zero when none is found.
manifest_for() {
	local pid="$1" d
	local -a dirs=()
	[ -n "${RYOKU_PLUGINS_DIR:-}" ] && IFS=':' read -r -a dirs <<<"$RYOKU_PLUGINS_DIR"
	dirs+=("$data_home/ryoku/plugins")
	for d in "${dirs[@]}"; do
		[ -n "$d" ] && [ -f "$d/$pid/manifest.json" ] && { printf '%s\n' "$d/$pid/manifest.json"; return 0; }
	done
	return 1
}

# Inject a plugin's shipped presets - its default host and default settings - into
# its plugins.json entry, filling only what is missing so a user's edits survive.
# Best-effort and idempotent: no manifest means nothing to seed.
seed_entry() {
	local pid="$1" man defs host
	man="$(manifest_for "$pid")" || return 0
	# Defaults come from the settings schema (metadata.settings[].default); a plugin
	# with the older flat metadata.defaultSettings still works.
	defs="$(jq -c 'if (.metadata.settings | type) == "array" then (.metadata.settings | map({(.key): .default}) | add // {}) else (.metadata.defaultSettings // {}) end' "$man")"
	host="$(jq -r '.defaults.host // "desktopWidget"' "$man")"
	jq --arg id "$pid" --argjson defs "$defs" --arg host "$host" \
		'.[$id] = ((.[$id] // {}) + {
			enabled: ((.[$id].enabled) // false),
			host: ((.[$id].host) // $host),
			settings: ($defs + ((.[$id].settings) // {}))
		})' "$f" >"$tmp" && mv "$tmp" "$f"
}

case "$field" in
desktopWidget)
	x="${1:?x}"; y="${2:?y}"; scale="${3:-}"; locked="${4:-}"
	# scale/locked are optional: keep the existing value (or a sane default) when
	# not passed, so a position-only write never drops them.
	jq --arg id "$id" --argjson x "$x" --argjson y "$y" \
		--arg scale "$scale" --arg locked "$locked" \
		'.[$id] = ((.[$id] // {}) + {
			enabled: ((.[$id].enabled) // true),
			host: ((.[$id].host) // "desktopWidget"),
			desktopWidget: (((.[$id].desktopWidget) // {}) + { x: $x, y: $y }
				+ (if $scale == "" then {} else { scale: ($scale | tonumber) } end)
				+ (if $locked == "" then {} else { locked: ($locked == "true") } end))
		})' "$f" >"$tmp" && mv "$tmp" "$f"
	;;
framePopout)
	edge="${1:?edge}"; align="${2:-start}"; hoverW="${3:-320}"; hoverH="${4:-16}"
	jq --arg id "$id" --arg e "$edge" --arg a "$align" --argjson hw "$hoverW" --argjson hh "$hoverH" \
		'.[$id] = ((.[$id] // {}) + { enabled: ((.[$id].enabled) // true), host: ((.[$id].host) // "framePopout"), framePopout: (((.[$id].framePopout) // {}) + { edge: $e, align: $a, hoverW: $hw, hoverH: $hh }) })' \
		"$f" >"$tmp" && mv "$tmp" "$f"
	;;
host)
	host="${1:?host}"
	jq --arg id "$id" --arg h "$host" '.[$id] = ((.[$id] // {}) + { enabled: ((.[$id].enabled) // true), host: $h })' "$f" >"$tmp" && mv "$tmp" "$f"
	;;
enabled)
	en="${1:?enabled}"
	jq --arg id "$id" --argjson e "$en" '.[$id] = ((.[$id] // {}) + { enabled: $e })' "$f" >"$tmp" && mv "$tmp" "$f"
	# Enabling injects the preset block, so a plugin's settings exist in the right
	# place the moment it goes live (a fresh enable needs no hand edit).
	if [ "$en" = "true" ]; then seed_entry "$id"; fi
	;;
settings)
	json="${1:?settings json}"
	jq --arg id "$id" --argjson s "$json" \
		'.[$id] = ((.[$id] // {}) + { settings: (((.[$id].settings) // {}) + $s) })' \
		"$f" >"$tmp" && mv "$tmp" "$f"
	;;
seed)
	seed_entry "$id"
	;;
forget)
	jq --arg id "$id" 'del(.[$id])' "$f" >"$tmp" && mv "$tmp" "$f"
	;;
*)
	echo "usage: ryoku-plugins-place <id> desktopWidget <x> <y> | framePopout <edge> <align> <hoverW> <hoverH> | host <name> | enabled <bool> | settings <json> | seed | forget" >&2
	exit 2
	;;
esac
