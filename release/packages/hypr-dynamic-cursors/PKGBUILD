# Maintainer: Ryoku <releases@ryoku.dev>
#
# hypr-dynamic-cursors: a Hyprland compositor plugin for realistic cursor motion
# (rotate / tilt / stretch) and shake-to-find magnify. Installed as a plain .so
# under /usr/lib/hyprland/plugins/, loaded by the Hub's generated settings.lua
# (Cursor tab) via hl.plugin.load; a missing or ABI-mismatched plugin is guarded
# there, so it degrades to off instead of erroring the config.
#
# Hyprland plugins are ABI-locked to the compositor. prepare() reads the build
# host's Hyprland version and checks out the matching plugin commit from
# upstream's hyprpm.toml (the same version map hyprpm uses), so a [ryoku] rebuild
# always builds against whatever Hyprland it ships, with no manual commit bumps.
# makepkg fetches upstream at build time (git source).
pkgname=hypr-dynamic-cursors
pkgver=${RYOKU_PKGVER:-0.1.0}
pkgrel=1
pkgdesc="Hyprland plugin: realistic cursor motion and shake-to-find"
arch=('x86_64')
url="https://github.com/VirtCode/hypr-dynamic-cursors"
license=('GPL-3.0-or-later')
depends=('hyprland')
makedepends=('hyprland' 'hyprcursor' 'pkgconf' 'make' 'gcc' 'git')
source=("$pkgname::git+https://github.com/VirtCode/hypr-dynamic-cursors.git")
sha256sums=('SKIP')

prepare() {
  cd "$srcdir/$pkgname"
  local hv commit
  hv="$(pkg-config --modversion hyprland)"
  # hyprpm.toml lines: ["<hyprland-commit>", "<plugin-commit>"], # <version>
  commit="$(grep -F "$hv" hyprpm.toml | grep -oE '[0-9a-f]{40}' | sed -n 2p)"
  [[ -n "$commit" ]] || { echo "PKGBUILD: no hyprpm.toml pin for Hyprland $hv" >&2; return 1; }
  echo "PKGBUILD: $pkgname -> $commit (Hyprland $hv)"
  git checkout -q "$commit"
}

build() {
  cd "$srcdir/$pkgname"
  make all
}

package() {
  install -Dm755 "$srcdir/$pkgname/out/dynamic-cursors.so" \
    "$pkgdir/usr/lib/hyprland/plugins/dynamic-cursors.so"
}
