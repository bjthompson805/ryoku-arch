# Maintainer: Ryoku <releases@ryoku.dev>
#
# awww = the animated wallpaper daemon the shell drives. ryoku/shell/ipc/wallpaper.go
# runs `awww img <image>` with a random transition preset on every wallpaper set
# and Super+W cycle, and starts `awww-daemon` on demand; without it a fresh desktop
# shows no wallpaper at all and the ryowalls picker can list images but set none.
# It is therefore a hard ryoku-desktop dependency, not a best-effort extra.
#
# shipped from [ryoku] instead of the AUR on purpose. awww is AUR-only (it is swww
# renamed: archived on GitHub, continued on Codeberg), so the installer's
# best-effort AUR step (skipped offline, warn-and-continue on a failed build) and
# `ryoku update` (pacman, never touches the AUR) could not guarantee it: a box that
# built the AUR package failed, installed offline, or predated the swww->awww rename
# came up with no wallpaper daemon and only a manual `ryoku doctor` to heal it.
# Building it here as a signed [ryoku] package makes it resolve as a hard depend and
# reach every box on install and on `ryoku update`, exactly like wallust and ffmpeg.
#
# fixed-version package: it tracks upstream awww releases, not the monorepo
# RYOKU_PKGVER. To follow a new awww release, bump pkgver + _commit and reset
# pkgrel; bump pkgrel alone when only this recipe changes. build-repo.sh adopts the
# already-published bytes for an unchanged filename, so a rebuild at the same pkgver
# never breaks clients holding the previous db.
pkgname=awww
pkgver=0.12.1
pkgrel=1
# the commit the upstream v0.12.1 tag points at, pinned so the build is immune to
# Codeberg regenerating the tag's archive bytes (the drift that broke the AUR
# wallust pin, see ../wallust/PKGBUILD).
_commit=f66e12a76dbc4c669b2f1375f78bce49f5b19d66
pkgdesc="Efficient animated wallpaper daemon for Wayland (the Ryoku shell's wallpaper backend)"
arch=('x86_64')
url="https://codeberg.org/LGFae/awww"
license=('GPL-3.0-or-later')
# liblz4 is probed by common/build.rs (pkg-config) and linked at runtime; the rest
# is the usual Rust/glibc runtime. build-repo.sh runs makepkg --nodeps, so lz4 must
# also be present on the build host (see .github/workflows/publish-repo.yml).
depends=('glibc' 'gcc-libs' 'lz4')
makedepends=('cargo' 'git' 'pkgconf')
# the release profile in Cargo.toml sets lto=true itself; keep makepkg from
# injecting its own conflicting LTO flags (same as ../wallust/PKGBUILD).
options=('!lto')
source=("$pkgname::git+https://codeberg.org/LGFae/awww.git#commit=$_commit")
sha256sums=('SKIP')

prepare() {
  cd "$pkgname"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "$pkgname"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  # the workspace's default members are the client (awww) and daemon (awww-daemon).
  # avif/jxl are opt-in features left off, so the default build needs no dav1d.
  cargo build --frozen --release
}

package() {
  cd "$pkgname"
  install -Dm755 -t "$pkgdir/usr/bin" target/release/awww target/release/awww-daemon
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/awww/LICENSE"
}
