#!/usr/bin/env bash
# Game Mode WiFi PS toggle (privileged). 802.11 PS off = the radio stays
# fully awake, killing the periodic micro-sleeps that spike latency on an
# idle link. pure latency change: no reconnect, no throughput cap, link is
# never dropped. iw talks to nl80211 (CAP_NET_ADMIN) so we go through pkexec
# as root. 49-ryoku-wifi-powersave.rules permits this exact binary for
# wheel with no password, so Game Mode stays one click. per-device state is
# stashed on `off` and put back on `on`, non-destructive.
#
#   off     = save each device's PS state, then disable it
#   on      = restore the saved state (default: enabled, the driver default)
#   status  = print each WiFi device and its current PS state
set -u

state="${RYOKU_WIFI_PS_STATE:-/run/ryoku/wifi-powersave.prev}"
sysfs="${RYOKU_NET_SYSFS:-/sys/class/net}"

wifi_devs() {
  local w dev
  for w in "$sysfs"/*/wireless; do
    [[ -e $w ]] || continue
    dev="${w%/wireless}"
    printf '%s\n' "${dev##*/}"
  done
}

# current 802.11 PS state of one device: "on" / "off".
ps_state() {
  iw dev "$1" get power_save 2>/dev/null | grep -qi 'power save: on' && echo on || echo off
}

case "${1:-}" in
  status)
    command -v iw >/dev/null 2>&1 || { echo "iw not installed" >&2; exit 1; }
    mapfile -t devs < <(wifi_devs)
    for d in "${devs[@]}"; do printf '%s %s\n' "$d" "$(ps_state "$d")"; done
    ;;
  off)
    command -v iw >/dev/null 2>&1 || exit 0
    mkdir -p "$(dirname "$state")" 2>/dev/null || true
    : >"$state" 2>/dev/null || true
    mapfile -t devs < <(wifi_devs)
    for d in "${devs[@]}"; do
      printf '%s %s\n' "$d" "$(ps_state "$d")" >>"$state" 2>/dev/null || true
      iw dev "$d" set power_save off 2>/dev/null || true
    done
    ;;
  on)
    command -v iw >/dev/null 2>&1 || exit 0
    declare -A prev=()
    if [[ -r $state ]]; then
      while read -r d s; do [[ -n $d ]] && prev[$d]="$s"; done <"$state"
    fi
    mapfile -t devs < <(wifi_devs)
    for d in "${devs[@]}"; do
      iw dev "$d" set power_save "${prev[$d]:-on}" 2>/dev/null || true
    done
    rm -f "$state" 2>/dev/null || true
    ;;
  *)
    echo "usage: ryoku-wifi-powersave [off | on | status]" >&2
    exit 2
    ;;
esac
