#!/usr/bin/env bash

# ryoku-mic normalizes the default microphone so speech-to-text (Handy) and the
# pill voice visualizer get clean input. Some laptop codecs let the capture gain
# run far above the hardware's 0 dB point: WirePlumber maps a 100% source to the
# codec's maximum analog gain (e.g. +30 dB), which clips every word into broken,
# distorted audio. This caps the default source at its Base Volume, the level the
# device reports as 0 dB hardware gain (no amplification), so an over-amplified
# mic drops to unity while a mic already at or below unity is left alone. The
# level is read from the device, so nothing machine-specific is baked in.

set -euo pipefail

# levels SOURCE prints "<current> <base>" raw volumes for the named source, or
# nothing when either cannot be read.
levels() {
  local src=$1
  LC_ALL=C pactl list sources 2>/dev/null | awk -v n="$src" '
    $1 == "Source" { insec = 0 }
    index($0, "Name: " n) { insec = 1 }
    insec && /Volume:/ && $1 != "Base" && cur == "" {
      for (i = 1; i <= NF; i++) if ($i ~ /^[0-9]+$/) { cur = $i; break }
    }
    insec && /Base Volume:/ {
      for (i = 1; i <= NF; i++) if ($i ~ /^[0-9]+$/) { base = $i; break }
    }
    END { if (cur != "" && base != "") print cur, base }
  '
}

apply() {
  command -v pactl >/dev/null 2>&1 || return 0

  local src
  src=$(pactl get-default-source 2>/dev/null) || return 0
  [[ -n $src && $src != auto_null ]] || return 0

  local cur base
  read -r cur base < <(levels "$src") || return 0
  [[ -n ${cur:-} && -n ${base:-} ]] || return 0

  # Only pull an over-amplified mic down to unity; never raise a quiet one.
  (( cur > base )) || return 0

  if [[ ${RYOKU_DRYRUN:-0} == 1 ]]; then
    printf 'pactl set-source-volume %s %s\n' "$src" "$base"
    return 0
  fi

  pactl set-source-volume "$src" "$base"
}

status() {
  local src cur base
  src=$(pactl get-default-source 2>/dev/null || true)
  printf 'source=%s\n' "${src:-none}"
  [[ -n ${src:-} ]] || return 0
  read -r cur base < <(levels "$src") || true
  printf 'volume=%s base=%s\n' "${cur:-?}" "${base:-?}"
}

usage() {
  cat <<'USAGE'
Usage: ryoku-mic [apply|status]

apply   cap the default microphone at its Base Volume (0 dB hardware gain) so it
        does not clip; a mic at or below unity is left untouched
status  print the default source and its current and base raw volumes

Env:
  RYOKU_DRYRUN=1   print the pactl command instead of applying it
USAGE
}

cmd=${1:-apply}
case "$cmd" in
  apply) apply ;;
  status) status ;;
  -h | --help | help) usage ;;
  *)
    printf 'ryoku-mic: unknown command: %s\n' "$cmd" >&2
    usage >&2
    exit 2
    ;;
esac
