# 90-ryoku-gpu.rules
#
# Managed by Ryoku (system/hardware/gpu). For every PCI GPU, create a boot-stable,
# colon-free /dev/dri/ryoku-gpu-<pci-slot> symlink so Hyprland's AQ_DRM_DEVICES can
# pin the strongest GPU as the primary renderer.
#
# AQ_DRM_DEVICES separates devices with ':', so the /dev/dri/by-path names (full of
# colons) cannot be used, and bare /dev/dri/cardN can renumber across boots. We key
# the symlink on the PCI slot instead and map its colons and dot to '-':
#
#   0000:01:00.0  ->  /dev/dri/ryoku-gpu-0000-01-00-0
#
# How the token is built: %p is the device's devpath
# (/devices/.../0000:01:00.0/drm/card1). The first sed drops the /drm/cardN tail,
# the second keeps the trailing path component (the PCI slot), and tr maps ':' and
# '.' to '-'. %c is that program's output. KERNELS limits the rule to GPUs whose
# parent is a PCI device, so the slot is always present.
SUBSYSTEM=="drm", KERNEL=="card[0-9]*", KERNELS=="????:??:??.?", PROGRAM="/bin/sh -c 'echo %p | sed s#/drm/.*## | sed s#.*/## | tr :. -'", SYMLINK+="dri/ryoku-gpu-%c"
