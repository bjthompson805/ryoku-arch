#!/usr/bin/env bash

set -euo pipefail

palette_path() {
  printf '%s/wallust/hypr-colors.lua\n' "${XDG_CACHE_HOME:-$HOME/.cache}"
}

normalize_hex() {
  local hex=${1#\#}
  [[ $hex =~ ^[[:xdigit:]]{6}$ ]] || return 1
  printf '%s\n' "${hex^^}"
}

palette_color() {
  if [[ -n ${RYOKU_LEDS_COLOR:-} ]]; then
    normalize_hex "$RYOKU_LEDS_COLOR"
    return
  fi

  local file=${RYOKU_LEDS_PALETTE:-$(palette_path)}
  [[ -r $file ]] || return 1

  local line
  while IFS= read -r line; do
    if [[ $line =~ active[[:space:]]*=[[:space:]]*\"#?([[:xdigit:]]{6})\" ]]; then
      normalize_hex "${BASH_REMATCH[1]}"
      return
    fi
  done < "$file"

  return 1
}

lift_color() {
  local hex=$1
  local r=$((16#${hex:0:2}))
  local g=$((16#${hex:2:2}))
  local b=$((16#${hex:4:2}))
  local max=$r
  local target=${RYOKU_LEDS_MIN_CHANNEL:-96}

  (( g > max )) && max=$g
  (( b > max )) && max=$b

  if (( max == 0 )); then
    normalize_hex "${RYOKU_LEDS_FALLBACK:-F25623}"
    return
  fi

  if (( max < target )); then
    r=$(( r * target / max ))
    g=$(( g * target / max ))
    b=$(( b * target / max ))
  fi

  (( r > 255 )) && r=255
  (( g > 255 )) && g=255
  (( b > 255 )) && b=255
  printf '%02X%02X%02X\n' "$r" "$g" "$b"
}

led_color() {
  local hex
  hex=$(palette_color || normalize_hex "${RYOKU_LEDS_FALLBACK:-F25623}")
  lift_color "$hex"
}

apply_color() {
  local color=$1
  local runtime=${XDG_RUNTIME_DIR:-/tmp}
  local lock=$runtime/ryoku-leds.lock
  local timeout_s=${RYOKU_LEDS_TIMEOUT:-4s}

  exec 9>"$lock"
  flock -n 9 || exit 0

  if [[ ${RYOKU_DRYRUN:-0} == 1 ]]; then
    printf 'openrgb --noautoconnect --color %s\n' "$color"
    return
  fi

  if ! command -v openrgb >/dev/null 2>&1; then
    [[ ${RYOKU_LEDS_VERBOSE:-0} == 1 ]] && printf 'ryoku-leds: openrgb is not installed\n' >&2
    return
  fi

  if command -v timeout >/dev/null 2>&1; then
    timeout "$timeout_s" openrgb --noautoconnect --color "$color" >/dev/null 2>&1 || true
  else
    openrgb --noautoconnect --color "$color" >/dev/null 2>&1 || true
  fi
}

usage() {
  cat <<'USAGE'
Usage: ryoku-leds [apply|color|status]

apply   set OpenRGB devices to the current wallust accent color
color   print the LED color chosen from the wallust palette
status  print OpenRGB availability, palette path, and selected color

Env:
  RYOKU_LEDS_COLOR=RRGGBB       override wallust color
  RYOKU_LEDS_PALETTE=/path      override wallust hypr-colors.lua
  RYOKU_LEDS_FALLBACK=RRGGBB    fallback color when no palette exists
  RYOKU_LEDS_MIN_CHANNEL=0-255  raise very dark colors for visible LEDs
  RYOKU_LEDS_TIMEOUT=4s         bound OpenRGB device detection time
  RYOKU_DRYRUN=1                print the OpenRGB command instead of running it
USAGE
}

cmd=${1:-apply}
case "$cmd" in
  apply)
    apply_color "$(led_color)"
    ;;
  color)
    led_color
    ;;
  status)
    if command -v openrgb >/dev/null 2>&1; then
      printf 'openrgb=installed\n'
    else
      printf 'openrgb=missing\n'
    fi
    printf 'palette=%s\n' "${RYOKU_LEDS_PALETTE:-$(palette_path)}"
    printf 'color=%s\n' "$(led_color)"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    printf 'ryoku-leds: unknown command: %s\n' "$cmd" >&2
    usage >&2
    exit 2
    ;;
esac
