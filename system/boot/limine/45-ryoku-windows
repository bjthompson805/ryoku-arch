#!/usr/bin/env bash
#
# limine-entry-tool post.d hook. fires after Limine rewrites the boot menu
# (kernel install/upgrade/remove), so a Windows install on a separate drive
# keeps its chainload entry across updates, and gets picked up if it turns
# up later. no-op when the helper or Windows isn't around. never fatal.
command -v ryoku-windows-entry >/dev/null 2>&1 || exit 0
ryoku-windows-entry sync >/dev/null 2>&1 || true
exit 0
