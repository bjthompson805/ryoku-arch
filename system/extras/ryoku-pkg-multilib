#!/usr/bin/env bash

# Enable the [multilib] pacman repository, idempotently. Some bundles (Gaming)
# need 32-bit packages (Steam, the lib32 overlay libraries) that live only in
# multilib, so a bundle that declares `"requires": ["multilib"]` runs this before
# its packages are routed. Needs a TTY for the sudo password.

set -euo pipefail

conf=/etc/pacman.conf

if grep -qE '^\[multilib\]' "$conf"; then
  echo "multilib: already enabled"
  exit 0
fi

# Uncomment the commented multilib block (the [multilib] header and its Include
# line) shipped in the stock pacman.conf, then refresh that database.
sudo sed -i '/^#\[multilib\]/,/^#Include/ s/^#//' "$conf"
grep -qE '^\[multilib\]' "$conf" || {
  echo "ryoku-pkg-multilib: could not enable multilib in $conf" >&2
  exit 1
}
sudo pacman -Sy
