#!/bin/bash
# Ryoku post-commit: a non-blocking delivery report. right after a commit lands,
# it prints whether every config reaches an installed box and how far the
# published tree (main) lags development, so a delivery gap never goes unnoticed.
# never fails the commit; pre-commit already blocks a hard gap. see docs/updates.md.
bin/ryoku-dev-verify-delivery || true
