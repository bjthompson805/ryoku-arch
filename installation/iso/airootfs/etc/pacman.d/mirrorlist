# Ryoku live ISO mirrorlist, copied verbatim into the target (refine later, e.g.
# with reflector). Fastly's CDN leads: its edge POPs cache worldwide (incl. South
# America), so it stays fast where the DevOps geo mirror has no nearby origin.
# Then the routed geo mirror, then high-availability global backups.
Server = https://fastly.mirror.pkgbuild.com/$repo/os/$arch
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://mirror.leaseweb.net/archlinux/$repo/os/$arch
