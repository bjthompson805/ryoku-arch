# Ryoku live ISO mirrorlist. The first entry is Arch's worldwide geo-routed
# mirror, which resolves to a fast nearby server for any user; the rest are
# high-availability global backups. The installer copies this into the target,
# where it can be refined later.
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://mirror.leaseweb.net/archlinux/$repo/os/$arch
